{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "apps/tma/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/webhook",          "dest": "/api/webhook.py" },
    { "src": "/img/([^/]+)$",         "dest": "/apps/tma/img/$1" },
    { "src": "/([^/]+\\.json)$",      "dest": "/apps/tma/$1" },
    { "src": "/(.*)",                 "dest": "/apps/tma/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
