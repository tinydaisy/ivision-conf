{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "apps/tma/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/webhook$",                          "dest": "/api/webhook.py" },
    { "src": "^/img/(.+)$",                             "dest": "/apps/tma/img/$1" },
    { "src": "^/([^/]+\\.json)$",                       "dest": "/apps/tma/$1" },
    { "src": "^/tg-redirect\\.js$",                      "dest": "/apps/tma/tg-redirect.js" },
    { "src": "^/bot(\\.html)?$",                         "dest": "/apps/tma/bot.html" },
    { "src": "^/ivision-conf-7(\\.html)?$",             "dest": "/apps/tma/ivision-conf-7.html" },
    { "src": "^/ivision-for-speakers(\\.html)?$",       "dest": "/apps/tma/ivision-for-speakers.html" },
    { "src": "^/(.*)$",                                 "dest": "/apps/tma/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
